{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/sync.js": {
      "maxDuration": 300
    },
    "api/activity.js": {
      "maxDuration": 300
    },
    "api/sync-speed.js": {
      "maxDuration": 300
    },
    "api/finance.js": {
      "maxDuration": 120
    },
    "api/telegram-digest.js": {
      "maxDuration": 120
    },
    "api/dev-agent.js": {
      "maxDuration": 120
    },
    "api/growth-agent.js": {
      "maxDuration": 180
    }
  },
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/activity?action=refresh",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/sync-speed",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/gamification?action=recalc&cron=1&org=hunter",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/telegram-digest",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/dev-agent?action=nightly&cron=1",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/dev-agent?action=weekly_review&cron=1",
      "schedule": "30 0 * * 0"
    },
    {
      "path": "/api/growth-agent?action=cron_tick&cron=1",
      "schedule": "0 2 * * *"
    }
  ]
}
